# SuiPass Server (packages/server)
SUIPASS_MASTER_KEY=           # required: 64 hex chars (32 bytes); encrypts card bearer secrets at rest
SUIPASS_PACKAGE_ID=0x1d020a948ce614e47c60d3fa36b90a90e74672878fc881f3091272735a14e969  # published to testnet (original — use if cards were created with v1)
SUIPASS_GAS_SPONSOR_KEY=      # required: 64 hex chars (32 bytes); sponsor keypair for gasless transactions
SUIPASS_GOOGLE_CLIENT_ID=     # required: Google OAuth client ID for zkLogin
SUIPASS_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUIPASS_SUI_NETWORK=testnet
SUIPASS_DB_PATH=.dev/suipass.sqlite
PORT=4070
SUIPASS_PUBLIC_MCP_BASE=      # public origin for card URLs, e.g. https://api.example.com
SUIPASS_ALLOWED_HOSTS=        # extra Host headers accepted on MCP endpoints (comma-separated)
SUIPASS_DASHBOARD_BASE=       # dashboard origin for OAuth consent, e.g. https://app.example.com

# Venice AI (NL -> CardTerms compiler)
VENICE_API_KEY=               # Venice AI API key for the NL-to-terms compiler
VENICE_MODEL=qwen3-235b-a22b-instruct-2507

# OAuth 2.1 (per-card MCP access)
SUIPASS_OAUTH_ACCESS_TTL=3600
SUIPASS_OAUTH_REFRESH_TTL=2592000
SUIPASS_OAUTH_REDIRECT_HOSTS=
SUIPASS_OAUTH_ACCEPTED_RESOURCES=
SUIPASS_OAUTH_REGISTER_LIMIT=10
SUIPASS_OAUTH_AUTHORIZE_LIMIT=30
SUIPASS_OAUTH_TOKEN_LIMIT=60

# Optional tuning
SUIPASS_LOG_INTERVAL_MS=300000
SUIPASS_TRUST_PROXY_HOPS=1

# SuiPass Dashboard (packages/dashboard)
# The dashboard authenticates via zkLogin (Google OAuth id_token).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_SUIPASS_API=http://localhost:4070/api
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
NEXT_PUBLIC_SUIPASS_PACKAGE_ID=0x1d020a948ce614e47c60d3fa36b90a90e74672878fc881f3091272735a14e969
NEXT_PUBLIC_USDC_COIN_TYPE=0x5d4b302506645c37ff133b98c4b50a5ae14841659738d6d733d59d0d217a93bf::coin::COIN
NEXT_PUBLIC_ZKLOGIN_REDIRECT_URI=http://localhost:4071/api/auth/google/callback
NEXT_PUBLIC_SUIPASS_SERVER=http://localhost:4070
